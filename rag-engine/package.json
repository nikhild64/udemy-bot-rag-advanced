{
  "name": "rag-engine",
  "version": "0.1.0",
  "description": "Production-ready backend foundation for a modular RAG Knowledge Engine",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "discover": "tsx src/cli/discover.ts",
    "extract": "tsx src/cli/extract.ts",
    "manifest": "tsx src/cli/manifest.ts",
    "parse": "tsx src/cli/parse.ts",
    "chunk": "tsx src/cli/chunk.ts",
    "embed": "tsx src/cli/embed.ts",
    "index": "tsx src/cli/indexing.ts",
    "ingest": "tsx src/cli/indexing.ts",
    "vectorstore": "tsx src/cli/vectorstore.ts",
    "search": "tsx src/cli/search.ts",
    "prompt": "tsx src/cli/prompt.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "rag",
    "knowledge-engine",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/compress": "^9.1.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "dotenv": "^16.4.7",
    "extract-zip": "^2.0.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.9",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
